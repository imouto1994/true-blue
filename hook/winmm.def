; winmm.def - Module definition for winmm.dll proxy
LIBRARY winmm
EXPORTS
    mmioOpenA               = proxy_0
    timeBeginPeriod         = proxy_1
    timeSetEvent            = proxy_2
    timeKillEvent           = proxy_3
    timeEndPeriod           = proxy_4
    mmioGetInfo             = proxy_5
    mmioAdvance             = proxy_6
    mmioSetInfo             = proxy_7
    mmioSeek                = proxy_8
    mmioDescend             = proxy_9
    mmioRead                = proxy_10
    mmioAscend              = proxy_11
    mmioClose               = proxy_12
    mixerGetNumDevs         = proxy_13
    mixerOpen               = proxy_14
    mixerGetDevCapsA        = proxy_15
    mixerGetLineInfoA       = proxy_16
    mixerGetLineControlsA   = proxy_17
    mixerSetControlDetails  = proxy_18
    mixerGetControlDetailsA = proxy_19
    mixerClose              = proxy_20
    midiOutGetNumDevs       = proxy_21
    mciSendCommandA         = proxy_22
    mciGetErrorStringA      = proxy_23
    timeGetTime             = proxy_24
